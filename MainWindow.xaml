<Window x:Class="TaskManager_Markova.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskManager_Markova"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" FontFamily="Bahnschrift Light Condensed" WindowStyle="None">
    <Window.Resources>
        <Style TargetType="{x:Type Button}">
            <Setter Property="Background">
                <Setter.Value>
                    <ImageBrush ImageSource="/Images/free-icon-close-1828665.png"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}" BorderBrush="#00FFFF00"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="#F0F0F0">
        <Grid Height="50" VerticalAlignment="Top" Background="White">
            <Grid.Effect>
                <DropShadowEffect Opacity="0.1"/>
            </Grid.Effect>
            <Image
                Width="30"
                Height="30"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Margin="10" Source="/Images/free-icon-to-do-list-6811275.png"
                />
            <Label
                Content="Задачник"
                VerticalContentAlignment="Center"
                HorizontalContentAlignment="Center"
                FontSize="18"/>
            <Button
                Command="{Binding OnClose}"
                Width="20"
                Height="20"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="10">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
                </Button.Effect>
            </Button>
        </Grid>
        <Frame x:Name="frame" NavigationUIVisibility="Hidden" Margin="0,55,0,0"/>
    </Grid>
</Window>
